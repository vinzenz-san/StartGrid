  },
  "devDependencies": {
    "@rspack/cli": "^1.3.0",
    "@rspack/core": "^1.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/webextension-polyfill": "^0.10.0",
    "serve": "^14.2.6",
    "typescript": "^5.0.0"
  }
